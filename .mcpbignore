# Keep the .mcpb bundle minimal: ship only what `uv run` needs at runtime
# (manifest.json, pyproject.toml, uv.lock, src/, README.md, LICENSE).
# Everything below must never end up in the archive — see the forbidden-paths
# assertion in .github/workflows/mcpb.yml. In particular .env may hold secrets.

.env
.env.*
.git/
.github/
.venv/
venv/
dist/
build/
wheels/
*.egg-info/

# Tests, docs, dev tooling, local scratch
tests/
docs/
scripts/
Makefile
prek.toml
cwms-overview.md
CLAUDE.md
AGENTS.md
.agents/
.claude/
.ipynb_checkpoints/

# Caches and build artifacts
__pycache__/
*.py[oc]
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
*.mcpb

# OS cruft
.DS_Store
